#!/usr/bin/env python3
"""
sss — Smart Session Search
Hybrid BM25 (SQLite FTS5) + Semantic (fastembed) über Claude Code Sessions.

Usage:
  sss "Erklärvideo"                     # BM25 (schnell, default)
  sss "Erklärvideo" --semantic          # Semantic (pre-computed embeddings, ~0.4s)
  sss "Erklärvideo" --hybrid            # BM25 + Semantic kombiniert (beste Qualität)
  sss "V15" --project "SEO BASE"        # Projekt-Filter
  sss "V15" --role user                 # Nur User-Turns
  sss "V15" --since 2026-03-20          # Ab Datum
  sss "V15" --limit 5                   # Max N Ergebnisse
  sss "deploy" --deployed               # Nur Sessions mit Deploy-Befehl
  sss "wrangler" --milestone            # Nur Sessions mit Go-Live/Abschluss
  sss --index                           # FTS5 + Embeddings aufbauen/aktualisieren
  sss --index --force                   # Komplett neu aufbauen
  sss --fingerprint-all                 # Alle Sessions klassifizieren (Batch)
  sss --stats                           # Index-Statistiken
"""

import sqlite3
import json
import os
import sys
import re
import time
import argparse
from pathlib import Path
from datetime import datetime, timedelta

# --- Konfiguration (alle Pfade via Env-Vars überschreibbar) ---
# EXISTENZ_* hat Vorrang; SSS_* als Fallback für bestehende Installationen
def _env(*keys: str, default: str) -> str:
    for k in keys:
        if k in os.environ:
            return os.environ[k]
    return default

_data_dir = _env("EXISTENZ_DATA_DIR", "SSS_DATA_DIR", default=str(Path.home() / ".claude"))
_SSS_DATA_DIR = Path(_data_dir)
SESSIONS_BASE = Path(_env("EXISTENZ_SESSIONS_DIR", "SSS_SESSIONS_DIR", default=str(_SSS_DATA_DIR / "projects")))
INDEX_DB      = Path(_env("EXISTENZ_INDEX_DB",     "SSS_INDEX_DB",     default=str(_SSS_DATA_DIR / "session-index.db")))
EMBED_NPY     = Path(_env("EXISTENZ_EMBED_NPY",    "SSS_EMBED_NPY",    default=str(_SSS_DATA_DIR / "session-embeddings.npy")))
ROWIDS_NPY    = Path(_env("EXISTENZ_ROWIDS_NPY",   "SSS_ROWIDS_NPY",   default=str(_SSS_DATA_DIR / "session-rowids.npy")))
META_PKL      = Path(_env("EXISTENZ_META_PKL",     "SSS_META_PKL",     default=str(_SSS_DATA_DIR / "session-meta.pkl")))

# Embedding-Modell:
#   "BAAI/bge-small-en-v1.5"         — 33MB,  Englisch-optimiert (Default, schnell)
#   "BAAI/bge-m3"                     — 568MB, 100+ Sprachen, beste Qualität
#   "intfloat/multilingual-e5-small"  — 117MB, DE+EN optimiert, guter Kompromiss
EMBED_MODEL = _env("EXISTENZ_EMBED_MODEL", "SSS_EMBED_MODEL", default="BAAI/bge-small-en-v1.5")
EMBED_DIM   = 384  # gilt für alle drei Modelle oben


# --- Text-Normalisierung (German + CamelCase) ---
def normalize(text: str) -> str:
    """
    German-aware preprocessing für besseres FTS-Matching.
    'ErklaervideoV14' → 'erklaervideo v 14'
    'Erklärvideo'     → 'erklarervideo'  (matcht obiges)
    """
    if not text:
        return ""
    # Umlaute
    for a, b in [('ä','ae'),('ö','oe'),('ü','ue'),('Ä','Ae'),('Ö','Oe'),('Ü','Ue'),('ß','ss')]:
        text = text.replace(a, b)
    # camelCase aufbrechen: ErklaervideoV14 → Erklaervideo V14
    text = re.sub(r'([a-z])([A-Z])', r'\1 \2', text)
    # Buchstaben-Zahlen trennen: V14 → V 14, S08 → S 08
    text = re.sub(r'([A-Za-z])(\d+)', r'\1 \2', text)
    return text.lower()


def extract_text_from_message(msg: dict, include_tool_inputs: bool = True) -> str:
    """Extrahiert lesbaren Text aus einer Message-Struktur."""
    parts = []
    content = msg.get("content", "")

    if isinstance(content, str):
        parts.append(content)
    elif isinstance(content, list):
        for block in content:
            if not isinstance(block, dict):
                continue
            btype = block.get("type", "")
            if btype == "text":
                parts.append(block.get("text", ""))
            elif btype == "tool_use" and include_tool_inputs:
                inp = block.get("input", {})
                for k, v in inp.items():
                    if isinstance(v, str) and 5 < len(v) < 3000:
                        parts.append(v)
            elif btype == "tool_result":
                for sub in block.get("content", []):
                    if isinstance(sub, dict) and sub.get("type") == "text":
                        parts.append(sub.get("text", "")[:2000])

    return " ".join(parts).strip()


def extract_turns(jsonl_path: Path) -> list[dict]:
    """Extrahiert alle nutzbaren Turns aus einer JSONL-Session-Datei."""
    turns = []
    session_id = jsonl_path.stem
    project = jsonl_path.parent.name

    try:
        with open(jsonl_path, errors="replace") as f:
            for line in f:
                try:
                    obj = json.loads(line)
                    t = obj.get("type", "")
                    if t not in ("user", "assistant"):
                        continue

                    ts = obj.get("timestamp", "")[:19]
                    msg = obj.get("message", {})
                    text = extract_text_from_message(msg)

                    if not text or len(text) < 15:
                        continue

                    turns.append({
                        "session_id": session_id,
                        "project": project,
                        "timestamp": ts,
                        "role": t,
                        "text": text[:8000],       # Display-Text (original)
                        "normalized": normalize(text[:8000]),  # FTS-Index-Text
                    })
                except Exception:
                    continue
    except Exception:
        pass

    return turns


# --- Session-Fingerprinting ---

# Wörter die auf ein erfolgreich abgeschlossenes Milestone-Event hinweisen
_MILESTONE_PATTERNS = [
    r'\bgo.?live\b',
    r'\blive gegangen\b',
    r'\bdeployed?\b',
    r'\brelease\b',
    r'\babgeschlossen\b',
    r'\bfertig gestellt\b',
    r'\berfolgreich\b.*\bpush\b',
    r'\bpush.*\berfolgreich\b',
    r'\bergebnis.*\bfertig\b',
    r'\bscore.*\b(100|9[5-9])\b',
    r'\bpubliziert\b',
    r'\bveröffentlicht\b',
]

# Wörter die auf einen Deploy-Befehl hinweisen
_DEPLOY_PATTERNS = [
    r'\bwrangler\b',
    r'\bmake release\b',
    r'\bmake deploy\b',
    r'\bpush-config\b',
    r'\bpush-briefadler\b',
    r'\bpush-tkh\b',
    r'\bnpm run deploy\b',
    r'\bwrangler deploy\b',
    r'\bwrangler publish\b',
    r'\bcf.?deploy\b',
]

# Themen-Keywords → Cluster-Labels
_TOPIC_KEYWORDS: list[tuple[str, list[str]]] = [
    ("cloudflare",  ["cloudflare", "wrangler", "worker", "kv store", "edge seo", "cf proxy"]),
    ("briefadler",  ["briefadler", "brief adler", "outreach", "lead"]),
    ("tiroler",     ["tiroler", "kraeuterhof", "tee", "naturshampoo", "jtl"]),
    ("remotion",    ["remotion", "erklaervideo", "composition", "animation"]),
    ("facharzt",    ["facharzt", "psychiater", "dornbirn", "lenkeignung"]),
    ("bier-genuss", ["bier genuss", "bier-genuss", "berlin"]),
    ("seo",         ["sistrix", "sichtbarkeit", "ranking", "keyword", "serp"]),
    ("autonomous",  ["janitor", "autonomous", "cron", "launchagent", "sleep"]),
    ("csv",         ["csv", "jtl", "meta daten", "produkttext"]),
    ("preview",     ["preview engine", "kv push", "deploy briefadler"]),
    ("content",     ["artikel", "content factory", "blog", "text generierung"]),
    ("nanobot",     ["nanobot", "bridge", "gateway", "minimax"]),
]

_MILESTONE_RES = [re.compile(p, re.IGNORECASE) for p in _MILESTONE_PATTERNS]
_DEPLOY_RES    = [re.compile(p, re.IGNORECASE) for p in _DEPLOY_PATTERNS]


def fingerprint_session(turns: list[dict]) -> tuple[str, int, int]:
    """
    Klassifiziert eine Session anhand der letzten 20 Turns (oder aller wenn <20).

    Gibt zurück: (topics_json, milestone_detected, deploy_detected)
    topics_json = JSON-Array mit bis zu 5 Themen-Labels, z.B. '["cloudflare","seo"]'
    milestone_detected = 1 wenn mind. 1 Milestone-Pattern gefunden
    deploy_detected    = 1 wenn mind. 1 Deploy-Pattern gefunden
    """
    # Nur die letzten 20 Turns analysieren (effizienter, fokussierter)
    recent_turns = turns[-20:] if len(turns) > 20 else turns
    combined_text = " ".join(t.get("text", "") for t in recent_turns).lower()

    # Milestone prüfen: Pattern + Mindest-Turn-Schwelle (< 10 = Headless-Deploy, kein Milestone)
    pattern_hit = any(rx.search(combined_text) for rx in _MILESTONE_RES)
    milestone = int(pattern_hit and len(turns) >= 10)

    # Deploy prüfen
    deployed = int(any(rx.search(combined_text) for rx in _DEPLOY_RES))

    # Themen extrahieren (alle Turns, nicht nur letzte 20 — für bessere Abdeckung)
    all_text = " ".join(t.get("text", "") for t in turns).lower()
    found_topics = []
    for label, keywords in _TOPIC_KEYWORDS:
        if any(kw in all_text for kw in keywords):
            found_topics.append(label)

    topics_json = json.dumps(found_topics[:5], ensure_ascii=False)
    return topics_json, milestone, deployed


def fingerprint_all(verbose: bool = True) -> int:
    """
    Batch-Fingerprinting für alle bestehenden Sessions in der DB.

    Liest JSONL-Dateien, berechnet Fingerprint, schreibt in sessions_meta.
    Überspringt Sessions die bereits fingerprinted sind (topics IS NOT NULL).
    Gibt Anzahl neu fingerprinted Sessions zurück.
    """
    conn = get_db()

    # Sessions die noch kein Fingerprint haben
    unfingered = {row[0] for row in conn.execute(
        "SELECT session_id FROM sessions_meta WHERE topics IS NULL"
    )}

    if not unfingered:
        if verbose:
            print("Alle Sessions bereits fingerprinted.")
        return 0

    if verbose:
        print(f"Fingerprinting: {len(unfingered)} Sessions ohne Klassifizierung...")

    # JSONL-Dateien finden
    jsonl_map: dict[str, Path] = {}
    for item in SESSIONS_BASE.iterdir():
        if item.is_dir():
            for f in item.glob("*.jsonl"):
                if f.stem in unfingered:
                    jsonl_map[f.stem] = f
        elif item.suffix == ".jsonl" and item.stem in unfingered:
            jsonl_map[item.stem] = item

    done = 0
    for i, (sid, jsonl_path) in enumerate(jsonl_map.items()):
        turns = extract_turns(jsonl_path)
        if not turns:
            # Session ohne Turns: leere Defaults setzen
            conn.execute(
                "UPDATE sessions_meta SET topics=?, milestone_detected=?, deploy_detected=? WHERE session_id=?",
                ('[]', 0, 0, sid)
            )
            done += 1
            continue

        topics_json, milestone, deployed = fingerprint_session(turns)
        conn.execute(
            "UPDATE sessions_meta SET topics=?, milestone_detected=?, deploy_detected=? WHERE session_id=?",
            (topics_json, milestone, deployed, sid)
        )
        done += 1

        if (i + 1) % 50 == 0:
            conn.commit()
            if verbose:
                print(f"  {i+1}/{len(jsonl_map)} Sessions fingerprinted...")

    conn.commit()

    # active_minutes rückwirkend für alle Sessions ohne Wert berechnen
    missing_time = conn.execute(
        "SELECT session_id, first_ts, last_ts, turn_count FROM sessions_meta WHERE active_minutes IS NULL"
    ).fetchall()
    if missing_time:
        if verbose:
            print(f"Berechne active_minutes für {len(missing_time)} Sessions...")
        for sid, first_ts_str, last_ts_str, turn_count in missing_time:
            calendar_minutes = 0
            if first_ts_str and last_ts_str and first_ts_str != last_ts_str:
                try:
                    t_first = datetime.fromisoformat(first_ts_str)
                    t_last  = datetime.fromisoformat(last_ts_str)
                    calendar_minutes = (t_last - t_first).total_seconds() / 60
                except Exception:
                    calendar_minutes = 0
            active_minutes = int(min((turn_count or 0) * 3, calendar_minutes))
            conn.execute(
                "UPDATE sessions_meta SET active_minutes=? WHERE session_id=?",
                (active_minutes, sid)
            )
        conn.commit()

    if verbose:
        # Zusammenfassung
        totals = conn.execute(
            "SELECT COUNT(*), SUM(milestone_detected), SUM(deploy_detected) FROM sessions_meta"
        ).fetchone()
        print(f"Fertig: {done} neu fingerprinted | "
              f"Milestones gesamt: {totals[1]} | Deploys gesamt: {totals[2]}")

    return done


# --- Datenbank ---
def get_db() -> sqlite3.Connection:
    conn = sqlite3.connect(INDEX_DB)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA cache_size=-32768")  # 32MB page cache

    conn.execute("""
        CREATE TABLE IF NOT EXISTS sessions_meta (
            session_id TEXT PRIMARY KEY,
            project TEXT,
            first_ts TEXT,
            last_ts TEXT,
            turn_count INTEGER,
            indexed_at TEXT,
            embedded_at TEXT DEFAULT NULL
        )
    """)

    # FTS5: content = normalisierter Text (wird durchsucht)
    # alle anderen Felder UNINDEXED = nur gespeichert, nicht durchsucht
    conn.execute("""
        CREATE VIRTUAL TABLE IF NOT EXISTS turns_fts USING fts5(
            session_id UNINDEXED,
            project UNINDEXED,
            timestamp UNINDEXED,
            role UNINDEXED,
            text UNINDEXED,
            content,
            tokenize='unicode61 remove_diacritics 2'
        )
    """)

    # turns_vec: rowid PRIMARY KEY = FTS5 rowid (monoton, 1:1-Mapping)
    # embedding BLOB = float32 array (EMBED_DIM * 4 bytes pro Row)
    conn.execute("""
        CREATE TABLE IF NOT EXISTS turns_vec (
            rowid INTEGER PRIMARY KEY,
            embedding BLOB
        )
    """)

    # Schema-Migration: Spalten zu bestehenden DBs hinzufügen (idempotent)
    migrations = [
        "ALTER TABLE sessions_meta ADD COLUMN embedded_at TEXT DEFAULT NULL",
        "ALTER TABLE sessions_meta ADD COLUMN topics TEXT DEFAULT NULL",
        "ALTER TABLE sessions_meta ADD COLUMN milestone_detected INTEGER DEFAULT 0",
        "ALTER TABLE sessions_meta ADD COLUMN deploy_detected INTEGER DEFAULT 0",
        "ALTER TABLE sessions_meta ADD COLUMN active_minutes INTEGER DEFAULT NULL",
    ]
    for sql in migrations:
        try:
            conn.execute(sql)
        except sqlite3.OperationalError:
            pass  # Spalte existiert bereits

    conn.commit()
    return conn


# --- Embedding-Modell ---
_embed_model = None

def get_embed_model():
    global _embed_model
    if _embed_model is None:
        try:
            from fastembed import TextEmbedding
            _embed_model = TextEmbedding(EMBED_MODEL)
        except Exception as e:
            print(f"Embedding-Modell nicht verfügbar: {e}", file=sys.stderr)
            return None
    return _embed_model


# --- Index aufbauen ---
def build_index(force: bool = False, project_filter: str = None, verbose: bool = True):
    """
    Baut FTS5-Index + Embeddings auf (inkrementell).

    Phase 1: Neue Sessions → FTS5 + Embeddings
    Phase 2: Bestehende Sessions ohne Embeddings nachholen (Einmal-Migration)
    """
    try:
        import numpy as np
    except ImportError:
        print("numpy fehlt: pip3 install numpy --break-system-packages", file=sys.stderr)
        return 0

    conn = get_db()
    t0 = time.time()

    # Alle JSONL-Dateien finden
    jsonl_files = []
    for item in SESSIONS_BASE.iterdir():
        if item.is_dir():
            jsonl_files.extend(item.glob("*.jsonl"))
        elif item.suffix == ".jsonl":
            jsonl_files.append(item)

    if project_filter:
        jsonl_files = [f for f in jsonl_files if project_filter.lower() in str(f.parent).lower()]

    if not force:
        indexed = {row[0] for row in conn.execute("SELECT session_id FROM sessions_meta")}
        new_files = [f for f in jsonl_files if f.stem not in indexed]
    else:
        conn.execute("DELETE FROM turns_fts")
        conn.execute("DELETE FROM turns_vec")
        conn.execute("DELETE FROM sessions_meta")
        conn.commit()
        new_files = jsonl_files

    if verbose:
        already = len(jsonl_files) - len(new_files)
        print(f"Index-Update: {len(new_files)} neue Sessions (bereits: {already})")

    # Embedding-Modell vorladen (cached nach erstem Aufruf)
    embed_model = None
    try:
        from fastembed import TextEmbedding
        embed_model = TextEmbedding(EMBED_MODEL)
    except Exception as e:
        if verbose and new_files:
            print(f"  Embedding nicht verfügbar — nur BM25: {e}", file=sys.stderr)

    # === Phase 1: Neue Sessions (FTS5 + Embeddings) ===
    inserted_turns = 0
    for i, jsonl_path in enumerate(new_files):
        turns = extract_turns(jsonl_path)
        if not turns:
            continue

        session_id = turns[0]["session_id"]

        # FTS5 einlesen
        conn.executemany(
            "INSERT INTO turns_fts(session_id, project, timestamp, role, text, content) VALUES (?,?,?,?,?,?)",
            [(t["session_id"], t["project"], t["timestamp"], t["role"],
              t["text"], t["normalized"]) for t in turns]
        )

        # Rowids der eben eingefügten Turns (FTS5 rowids sind monoton steigend)
        max_row = conn.execute("SELECT MAX(rowid) FROM turns_fts").fetchone()
        if max_row and max_row[0] is not None:
            max_rowid = max_row[0]
            rowids = list(range(max_rowid - len(turns) + 1, max_rowid + 1))

            # Embeddings für diese Session (in Batches)
            if embed_model is not None:
                texts = [t["text"][:128] for t in turns]  # 128 chars reicht für Semantik, 3x schneller
                batch_size = 64  # kleinere Batches = weniger peak memory
                all_blobs = []
                for bi in range(0, len(texts), batch_size):
                    vecs = list(embed_model.embed(texts[bi:bi+batch_size]))
                    for vec in vecs:
                        all_blobs.append(np.array(vec, dtype=np.float32).tobytes())
                conn.executemany(
                    "INSERT OR REPLACE INTO turns_vec(rowid, embedding) VALUES (?, ?)",
                    [(rowids[j], all_blobs[j]) for j in range(len(rowids))]
                )

        # Sessions-Meta + Fingerprinting
        timestamps = [t["timestamp"] for t in turns if t["timestamp"]]
        now_iso = datetime.now().isoformat()
        topics_json, milestone, deployed = fingerprint_session(turns)

        # active_minutes: realistischerer Schätzwert als Kalenderzeit
        # max 3 Minuten pro Turn, gedeckelt durch tatsächliche Kalenderzeit
        first_ts_str = min(timestamps, default="")
        last_ts_str  = max(timestamps, default="")
        calendar_minutes = 0
        if first_ts_str and last_ts_str and first_ts_str != last_ts_str:
            try:
                t_first = datetime.fromisoformat(first_ts_str)
                t_last  = datetime.fromisoformat(last_ts_str)
                calendar_minutes = (t_last - t_first).total_seconds() / 60
            except Exception:
                calendar_minutes = 0
        active_minutes = int(min(len(turns) * 3, calendar_minutes))

        conn.execute(
            """INSERT OR REPLACE INTO sessions_meta
               (session_id, project, first_ts, last_ts, turn_count, indexed_at, embedded_at,
                topics, milestone_detected, deploy_detected, active_minutes)
               VALUES (?,?,?,?,?,?,?,?,?,?,?)""",
            (session_id, turns[0]["project"],
             first_ts_str, last_ts_str,
             len(turns), now_iso,
             now_iso if embed_model is not None else None,
             topics_json, milestone, deployed, active_minutes)
        )
        inserted_turns += len(turns)

        if (i + 1) % 50 == 0:
            conn.commit()
            if verbose:
                elapsed = time.time() - t0
                print(f"  {i+1}/{len(new_files)} Sessions ({elapsed:.0f}s)...")

    conn.commit()

    elapsed = time.time() - t0
    total_sessions = conn.execute("SELECT COUNT(*) FROM sessions_meta").fetchone()[0]
    total_turns = conn.execute("SELECT COUNT(*) FROM turns_fts").fetchone()[0]
    total_vecs = conn.execute("SELECT COUNT(*) FROM turns_vec").fetchone()[0]

    if verbose:
        embed_info = f", {total_vecs:,} Embeddings" if total_vecs > 0 else ""
        print(f"Fertig in {elapsed:.1f}s — {total_sessions} Sessions, {total_turns:,} Turns{embed_info}")

    return inserted_turns


# --- Embeddings nachberechnen (Einmal-Migration + laufende Pflege) ---
def build_embeddings(time_limit: int = 0, verbose: bool = True) -> int:
    """
    Berechnet Embeddings für alle Turns ohne Embedding.

    time_limit: max Sekunden (0 = unbegrenzt). Für Janitor-Integration.
    Gibt Anzahl neu eingebetteter Turns zurück.
    """
    try:
        import numpy as np
    except ImportError:
        print("numpy fehlt: pip3 install numpy --break-system-packages", file=sys.stderr)
        return 0

    conn = get_db()

    # Turns ohne Embedding finden
    unembedded = conn.execute("""
        SELECT f.rowid, f.text
        FROM turns_fts f
        LEFT JOIN turns_vec v ON f.rowid = v.rowid
        WHERE v.rowid IS NULL
        ORDER BY f.rowid
    """).fetchall()

    if not unembedded:
        if verbose:
            print("Alle Turns haben Embeddings.")
        return 0

    est_min = len(unembedded) / 20 / 60
    if verbose:
        print(f"Embeddings berechnen: {len(unembedded):,} Turns (~{est_min:.0f}min)", flush=True)

    try:
        from fastembed import TextEmbedding
        embed_model = TextEmbedding(EMBED_MODEL)
    except Exception as e:
        print(f"Embedding-Modell nicht verfügbar: {e}", file=sys.stderr)
        return 0

    batch_size = 64
    t0 = time.time()
    inserted = 0

    for bi in range(0, len(unembedded), batch_size):
        if time_limit and (time.time() - t0) > time_limit:
            if verbose:
                print(f"  Zeit-Limit {time_limit}s erreicht — {inserted:,} Turns eingebettet.", flush=True)
            break

        batch = unembedded[bi:bi+batch_size]
        texts = [r[1][:128] for r in batch]
        vecs = list(embed_model.embed(texts))
        conn.executemany(
            "INSERT OR REPLACE INTO turns_vec(rowid, embedding) VALUES (?, ?)",
            [(batch[j][0], np.array(vecs[j], dtype=np.float32).tobytes())
             for j in range(len(batch))]
        )
        inserted += len(batch)

        done_batches = (bi // batch_size) + 1
        if done_batches % 20 == 0:
            conn.commit()
            if verbose:
                elapsed = time.time() - t0
                rate = inserted / max(elapsed, 0.01)
                rem = (len(unembedded) - inserted) / max(rate, 1)
                print(f"  {inserted:,}/{len(unembedded):,} ({rate:.0f}/s, ~{rem/60:.1f}min)", flush=True)

    conn.commit()
    elapsed = time.time() - t0

    # embedded_at für eingebettete Sessions markieren
    conn.execute(
        "UPDATE sessions_meta SET embedded_at = ? WHERE embedded_at IS NULL",
        (datetime.now().isoformat(),)
    )
    conn.commit()

    total_vecs = conn.execute("SELECT COUNT(*) FROM turns_vec").fetchone()[0]
    total_turns = conn.execute("SELECT COUNT(*) FROM turns_fts").fetchone()[0]

    if verbose:
        print(f"Fertig: {inserted:,} neue Embeddings in {elapsed:.1f}s | "
              f"Gesamt: {total_vecs:,}/{total_turns:,} ({total_vecs/total_turns*100:.0f}%)", flush=True)

    # NPY-Cache aktualisieren (fast lookup für search_semantic)
    if inserted > 0:
        if verbose:
            print("  Schreibe NPY-Cache...", flush=True)
        sync_npy_cache(conn, verbose=verbose)

    return inserted


# --- NPY-Cache sync (schneller Lesepfad für Semantic Search) ---
def sync_npy_cache(conn=None, verbose=False) -> int:
    """
    Schreibt numpy binary cache + metadata pickle aus turns_vec.

    Dateien:
      EMBED_NPY   = pre-normalisierte float32 (N, 384)  → kein Normalisieren bei Suche
      ROWIDS_NPY  = int64 sorted (N,)                   → für searchsorted
      META_PKL    = pickle list[(rowid,sid,proj,ts,role)]→ kein FTS5-Scan bei Suche

    Performance nach sync:
      search_semantic() warm: ~0.3s (Bottleneck: query-embedding 0.12s)
    """
    try:
        import numpy as np
        import pickle
    except ImportError:
        return 0

    if conn is None:
        conn = get_db()

    # Embeddings laden
    vec_rows = conn.execute("SELECT rowid, embedding FROM turns_vec ORDER BY rowid").fetchall()
    if not vec_rows:
        if verbose:
            print("  Keine Embeddings in turns_vec — NPY-Cache nicht gebaut.", flush=True)
        return 0

    rowids = np.array([r[0] for r in vec_rows], dtype=np.int64)
    raw    = b"".join(r[1] for r in vec_rows)
    embs   = np.frombuffer(raw, dtype=np.float32).reshape(len(vec_rows), EMBED_DIM).copy()

    # Pre-normalisieren: spart 0.4s pro Suche (kein Normalisieren zur Query-Zeit)
    norms = np.linalg.norm(embs, axis=1, keepdims=True)
    norms[norms == 0] = 1.0
    embs_norm = embs / norms

    np.save(ROWIDS_NPY, rowids)
    np.save(EMBED_NPY,  embs_norm)

    # Metadata für embedded turns (kein FTS5-Scan bei Suche)
    # JOIN: nur Turns die Embeddings haben → N=35k statt 73k
    meta_rows = conn.execute("""
        SELECT f.rowid, f.session_id, f.project, f.timestamp, f.role
        FROM turns_fts f
        INNER JOIN turns_vec v ON f.rowid = v.rowid
        ORDER BY f.rowid
    """).fetchall()
    META_PKL.write_bytes(pickle.dumps(meta_rows, protocol=4))

    mb = EMBED_NPY.stat().st_size / 1024 / 1024
    mb_pkl = META_PKL.stat().st_size / 1024 / 1024
    if verbose:
        print(f"  NPY-Cache: {len(vec_rows):,} Embeddings → {mb:.1f} MB | "
              f"Meta-Pickle: {mb_pkl:.1f} MB", flush=True)
    return len(vec_rows)


# --- BM25-Suche ---
def escape_fts_query(query: str, any_mode: bool = False) -> str:
    """Escape special FTS5 characters, handle multi-word queries.

    any_mode=False (default): AND  — alle Wörter müssen im Turn vorkommen
    any_mode=True:            OR   — mind. ein Wort muss vorkommen (breitere Suche)
    """
    query = re.sub(r'["\*\(\)\:]', ' ', query)
    words = [w for w in query.strip().split() if w]
    if not words:
        return '""'
    sep = " OR " if any_mode else " "
    return sep.join(f'"{w}"' for w in words)


def utc_adjust_since(since: str) -> str:
    """
    Korrigiert --since Datum um UTC-Drift (Mac läuft CET = UTC+1/+2).
    DB speichert Timestamps in UTC → --since '2026-03-22' würde UTC-Mitternacht suchen,
    verliert aber Sessions von 23:00-00:00 CET.
    Fix: 1 Stunde abziehen → 'WHERE timestamp >= 2026-03-21T23:00:00'.
    """
    # Validierung: nur YYYY-MM-DD akzeptiert — DD.MM.YYYY wird sonst silent ignoriert
    import re as _re
    if since and not _re.match(r'^\d{4}-\d{2}-\d{2}', since):
        print(f"\033[33m⚠️  --since Format ungültig: '{since}' — erwartet YYYY-MM-DD (z.B. 2026-03-20)\033[0m", file=__import__('sys').stderr)
        return "1970-01-01T00:00:00"  # Kein Filter — ungültiges Format
    try:
        dt = datetime.fromisoformat(since)
        dt_adjusted = dt - timedelta(hours=1)
        return dt_adjusted.strftime("%Y-%m-%dT%H:%M:%S")
    except Exception:
        return since  # Fallback: unverändertes Datum


def search_bm25(query: str, project: str = None, role: str = None,
                since: str = None, limit: int = 10, any_mode: bool = False,
                milestone_only: bool = False, deployed_only: bool = False,
                oldest_first: bool = False) -> list[dict]:
    """BM25-Suche via SQLite FTS5."""
    conn = get_db()
    # sessions_meta hat regulären Index → O(1) Count (turns_fts Count = 3s FTS5-Scan)
    total = conn.execute("SELECT COUNT(*) FROM sessions_meta").fetchone()[0]
    if total == 0:
        return []

    norm_q = normalize(query)
    fts_q = escape_fts_query(norm_q, any_mode=any_mode)

    # Wenn Milestone/Deploy-Filter aktiv: zuerst erlaubte session_ids einschränken
    session_filter_clause = ""
    if milestone_only or deployed_only:
        filter_parts = []
        if milestone_only:
            filter_parts.append("milestone_detected = 1")
        if deployed_only:
            filter_parts.append("deploy_detected = 1")
        filter_sql = " AND ".join(filter_parts)
        valid_sids = {row[0] for row in conn.execute(
            f"SELECT session_id FROM sessions_meta WHERE {filter_sql}"
        )}
        if not valid_sids:
            return []
        # IN-Clause für SQLite (max 999 Elemente — kein Problem bei <500 Sessions)
        placeholders = ",".join("?" * len(valid_sids))
        session_filter_clause = f" AND session_id IN ({placeholders})"
        session_sid_params = list(valid_sids)
    else:
        session_sid_params = []

    conditions = "(turns_fts MATCH ?)"
    params = [fts_q]

    if project:
        conditions += " AND project LIKE ?"
        params.append(f"%{project.replace(' ', '%')}%")
    if role:
        conditions += " AND role = ?"
        params.append(role)
    if since:
        conditions += " AND timestamp >= ?"
        params.append(utc_adjust_since(since))

    conditions += session_filter_clause

    order_clause = "ORDER BY timestamp ASC" if oldest_first else "ORDER BY bm25(turns_fts)"

    try:
        rows = conn.execute(f"""
            SELECT
                session_id, project, timestamp, role, text,
                bm25(turns_fts) AS score,
                snippet(turns_fts, 5, '\033[33m', '\033[0m', '...', 30) AS snip
            FROM turns_fts
            WHERE {conditions}
            {order_clause}
            LIMIT ?
        """, params + session_sid_params + [limit]).fetchall()
    except sqlite3.OperationalError:
        try:
            rows = conn.execute(f"""
                SELECT session_id, project, timestamp, role, text,
                       bm25(turns_fts) AS score, text AS snip
                FROM turns_fts WHERE {conditions}
                {order_clause} LIMIT ?
            """, params + session_sid_params + [limit]).fetchall()
        except Exception:
            return []

    results = []
    for r in rows:
        sid, proj, ts, role_r, text, score, snip = r
        results.append({
            "session_id": sid,
            "project": proj,
            "timestamp": ts,
            "role": role_r,
            "score": score,
            "snippet": snip,
            "text_preview": text[:200],
        })
    return results


# --- Semantic-Suche (numpy memmap — schnell) ---
def search_semantic(query: str, project: str = None, role: str = None,
                    since: str = None, limit: int = 10,
                    milestone_only: bool = False, deployed_only: bool = False,
                    oldest_first: bool = False) -> list[dict]:
    """
    Semantic Search via numpy memmap.

    Performance: ~0.5s für 73k Turns (OS-gecacht nach erster Query: ~0.4s).
    Bottleneck: Query-Embedding (0.3s) + FTS5-Scan (0.1s) + numpy (0.05s).
    Voraussetzung: sss --embed ausgeführt (npy-Cache gebaut).

    Warum schnell: numpy-Dateien liegen nach erster Query im OS-Page-Cache
    → kein Disk-I/O mehr. Keine SQLite-JOIN über 112 MB BLOBs.
    """
    try:
        import numpy as np
    except ImportError:
        print("numpy fehlt: pip3 install numpy --break-system-packages", file=sys.stderr)
        return []

    # NPY-Cache prüfen
    if not EMBED_NPY.exists() or not ROWIDS_NPY.exists():
        # Fallback: NPY aus DB bauen falls turns_vec gefüllt
        conn = get_db()
        vec_count = conn.execute("SELECT COUNT(*) FROM turns_vec").fetchone()[0]
        if vec_count == 0:
            print("Keine Embeddings. Bitte ausführen: sss --embed", file=sys.stderr)
            return []
        print("NPY-Cache fehlt — baue aus DB...", file=sys.stderr)
        sync_npy_cache(conn)

    # Query embedden (Model gecacht, 0.3s beim ersten Aufruf)
    model = get_embed_model()
    if not model:
        return []

    query_vec = np.array(list(model.embed([query]))[0], dtype=np.float32)
    query_norm = query_vec / (np.linalg.norm(query_vec) or 1.0)

    conn = get_db()

    import pickle

    # Metadata aus Pickle laden (kein FTS5-Scan: 0.04s statt 2.66s)
    # meta_all[i] entspricht EMBED_NPY[i] — gleiche Reihenfolge (ORDER BY rowid)
    meta_all = pickle.loads(META_PKL.read_bytes())

    # Milestone/Deploy-Filter: erlaubte session_ids vorab laden
    allowed_sids = None
    if milestone_only or deployed_only:
        conn_f = get_db()
        filter_parts = []
        if milestone_only:
            filter_parts.append("milestone_detected = 1")
        if deployed_only:
            filter_parts.append("deploy_detected = 1")
        filter_sql = " AND ".join(filter_parts)
        allowed_sids = {row[0] for row in conn_f.execute(
            f"SELECT session_id FROM sessions_meta WHERE {filter_sql}"
        )}
        if not allowed_sids:
            return []

    # Filter in Python (schnell: ~0.01s für 39k Tuples)
    since_adjusted = utc_adjust_since(since) if since else None
    if project or role or since or allowed_sids is not None:
        pf = project.lower() if project else None
        filtered = [
            (i, m) for i, m in enumerate(meta_all)
            if (not pf or pf in m[2].lower())
            and (not role or m[4] == role)
            and (not since_adjusted or m[3] >= since_adjusted)
            and (allowed_sids is None or m[1] in allowed_sids)
        ]
        if not filtered:
            return []
        filter_indices, valid_meta = zip(*filtered)
        filter_indices = list(filter_indices)
    else:
        valid_meta   = meta_all
        filter_indices = None   # alle

    # Embeddings laden: immer ganzes File (58 MB, 0.05s nach OS-Cache)
    # Schneller als memmap + fancy indexing (1.1s für 39k Rows)
    all_embs = np.load(str(EMBED_NPY))    # pre-normalisiert, float32
    embs = all_embs[filter_indices] if filter_indices is not None else all_embs

    # Dot product = cosine (pre-normalisiert → normalization entfällt)
    scores = embs @ query_norm

    # Top-K: bei --oldest nach Timestamp sortieren statt nach Score
    if oldest_first:
        timestamps = [m[3] for m in valid_meta]
        top_k = sorted(range(len(valid_meta)), key=lambda i: timestamps[i])[:limit]
    else:
        top_k = np.argsort(scores)[::-1][:limit]

    # text nur für top-k nachladen (N=limit rowid-Lookups)
    conn = get_db()
    results = []
    for i in top_k:
        m = valid_meta[i]   # (rowid, sid, proj, ts, role)
        text_row = conn.execute(
            "SELECT text FROM turns_fts WHERE rowid = ?", (m[0],)
        ).fetchone()
        text = text_row[0] if text_row else ""
        results.append({
            "session_id": m[1],
            "project":    m[2],
            "timestamp":  m[3],
            "role":       m[4],
            "score":      float(scores[i]),
            "snippet":    text[:300],
            "text_preview": text[:200],
        })
    return results


# --- Hybrid RRF (Reciprocal Rank Fusion) ---
def reciprocal_rank_fusion(list1: list[dict], list2: list[dict], k: int = 60) -> list[dict]:
    """
    RRF kombiniert zwei Ranglisten zu einem finalen Ranking.
    Standard in hybrider Suche (Elasticsearch, Vespa etc.)
    Score = 1/(k + rank1) + 1/(k + rank2)
    """
    scores = {}
    snippets = {}
    meta = {}

    for rank, item in enumerate(list1):
        key = (item["session_id"], item["timestamp"])
        scores[key] = scores.get(key, 0) + 1.0 / (k + rank + 1)
        snippets[key] = item.get("snippet", "")
        meta[key] = item

    for rank, item in enumerate(list2):
        key = (item["session_id"], item["timestamp"])
        scores[key] = scores.get(key, 0) + 1.0 / (k + rank + 1)
        if key not in snippets:
            snippets[key] = item.get("snippet", "")
        if key not in meta:
            meta[key] = item

    sorted_keys = sorted(scores.keys(), key=lambda k: -scores[k])
    results = []
    for key in sorted_keys:
        item = dict(meta[key])
        item["score"] = scores[key]
        item["snippet"] = snippets[key]
        results.append(item)
    return results


# --- Output ---
def format_project(project: str) -> str:
    """Kürzt den Projekt-Pfad für lesbare Ausgabe."""
    p = project.replace("-Users-f-s-Desktop-", "~/")
    p = p.replace("-SCALE-GROUP-SEO-BASE", "SEO BASE")
    p = p.replace("-", " ").replace("~/ ", "~/")
    return p


def format_age(ts_str: str) -> str:
    """Relative Altersangabe eines Timestamps."""
    try:
        ts = datetime.fromisoformat(ts_str[:19])
        secs = (datetime.now() - ts).total_seconds()
        if secs < 3600:
            return f"\033[32mvor {int(secs/60)}m\033[0m"
        elif secs < 86400:
            return f"\033[32mvor {int(secs/3600)}h\033[0m"
        elif secs < 86400 * 7:
            return f"\033[33mvor {int(secs/86400)}d\033[0m"
        else:
            return f"\033[90mvor {int(secs/86400)}d\033[0m"
    except Exception:
        return ""


def print_results(results: list[dict], query: str, mode: str, elapsed: float,
                  any_mode: bool = False, zero_terms: list = None):
    if not results:
        print(f"\n  Keine Ergebnisse für '{query}' ({mode}, {elapsed:.2f}s)")
        if zero_terms:
            print(f"  \033[33m⚠️  Kein Match für: {', '.join(zero_terms)}\033[0m")
        print(f"  Tipp: sss --index  # Index aufbauen falls noch nicht geschehen")
        return

    print(f"\n\033[1m{'='*60}\033[0m")
    print(f"  {mode.upper()}: \"{query}\"")
    print(f"  {len(results)} Treffer in {elapsed:.2f}s")
    if zero_terms:
        print(f"  \033[33m⚠️  Kein Match für: {', '.join(zero_terms)} (ignoriert)\033[0m")
    print(f"\033[1m{'='*60}\033[0m\n")

    for i, r in enumerate(results, 1):
        ts = r.get("timestamp", "")[:16]
        sid_short = r.get("session_id", "")[:8]
        role = "USER" if r.get("role") == "user" else "ASST"
        proj = format_project(r.get("project", ""))
        snip = r.get("snippet", r.get("text_preview", ""))[:300]
        snip = " ".join(snip.split())
        age = format_age(r.get("timestamp", ""))

        print(f"  [{i}] {ts}  {role}  [{sid_short}]  ({proj})  {age}")
        print(f"       {snip}")
        print(f"       \033[36m→ read-session {sid_short} --last 5\033[0m\n")


