_FRICTION_TERMS = [
    "again", "same issue", "same problem", "same error", "still not",
    "keeps", "wieder", "immer noch", "nochmal", "schon wieder",
    "failed again", "broken again", "not working", "doesn't work",
    "funktioniert nicht", "klappt nicht", "geht nicht",
]

_ERROR_TERMS = [
    "error", "fehler", "exception", "traceback", "failed", "failure",
    "crash", "bug", "broken", "TypeError", "AttributeError", "KeyError",
    "404", "500", "403", "401", "timeout", "exit 1", "exit code 1",
]

def _bar(val: int, max_val: int, width: int = 28) -> str:
    if max_val == 0:
        return " " * width
    filled = int(round(val / max_val * width))
    return "█" * filled + "░" * (width - filled)

def analyze(mode: str):
    """
    Analytics over the full session index.

    mode: 'topics' | 'projects' | 'errors' | 'friction' | 'timeline' | <keyword>
    """
    conn = get_db()

    # ── Topic-Ranking ──────────────────────────────────────────────────────
    if mode == "topics":
        rows = conn.execute(
            "SELECT topics, turn_count FROM sessions_meta WHERE topics IS NOT NULL"
        ).fetchall()
        counts: dict[str, int] = {}
        for (topics_json, tc) in rows:
            try:
                for t in json.loads(topics_json):
                    counts[t] = counts.get(t, 0) + 1
            except Exception:
                pass
        if not counts:
            print("No topic data found. Run: existenz --fingerprint-all")
            return
        ranked = sorted(counts.items(), key=lambda x: x[1], reverse=True)
        max_v = ranked[0][1]
        total = sum(c for _, c in ranked)
        print()
        print("  ┌─────────────────────────────────────────────────────┐")
        print("  │  TOPIC RANKING — Sessions per topic                 │")
        print("  └─────────────────────────────────────────────────────┘")
        print()
        for topic, count in ranked[:20]:
            pct = count / total * 100
            bar = _bar(count, max_v)
            print(f"  {topic:<22} {bar}  {count:>4} sessions  ({pct:.1f}%)")
        print()
        print(f"  {len(ranked)} topics total · {total} sessions analyzed")
        print()

    # ── Project-Stats ──────────────────────────────────────────────────────
    elif mode == "projects":
        rows = conn.execute("""
            SELECT project,
                   COUNT(*) as sessions,
                   SUM(turn_count) as turns,
                   SUM(active_minutes) as mins,
                   SUM(milestone_detected) as milestones,
                   SUM(deploy_detected) as deploys
            FROM sessions_meta
            GROUP BY project
            ORDER BY sessions DESC
            LIMIT 25
        """).fetchall()
        if not rows:
            print("No project data found.")
            return
        max_s = max(r[1] for r in rows)
        print()
        print("  ┌───────────────────────────────────────────────────────────────┐")
        print("  │  PROJECT ANALYTICS                                            │")
        print("  └───────────────────────────────────────────────────────────────┘")
        print()
        print(f"  {'Project':<32} {'Sessions':>8} {'Turns':>7} {'Hours':>6} {'✓':>5} {'🚀':>5}")
        print(f"  {'─'*32} {'─'*8} {'─'*7} {'─'*6} {'─'*5} {'─'*5}")
        for (proj, sessions, turns, mins, milestones, deploys) in rows:
            hours = (mins or 0) / 60
            bar = _bar(sessions, max_s, 14)
            name = (proj or "—")[:31]
            print(f"  {name:<32} {bar} {sessions:>3}   {turns or 0:>7}  {hours:>5.1f}h  {milestones or 0:>4}  {deploys or 0:>4}")
        print()
        total_sessions = sum(r[1] for r in rows)
        total_hours = sum((r[3] or 0) for r in rows) / 60
        print(f"  Total: {total_sessions} sessions · {total_hours:.0f}h working time")
        print()

    # ── Error-Analysis ─────────────────────────────────────────────────────
    elif mode == "errors":
        pattern = " OR ".join(f'"{t}"' for t in _ERROR_TERMS[:12])
        rows = conn.execute(f"""
            SELECT strftime('%Y-%W', timestamp) as week,
                   session_id, project, text
            FROM turns_fts
            WHERE turns_fts MATCH ?
            ORDER BY timestamp DESC
            LIMIT 500
        """, (pattern,)).fetchall()

        by_project: dict[str, int] = {}
        by_week: dict[str, int] = {}
        for (week, sid, proj, text) in rows:
            by_project[proj or "—"] = by_project.get(proj or "—", 0) + 1
            by_week[week or "—"]    = by_week.get(week or "—", 0) + 1

        print()
        print("  ┌─────────────────────────────────────────────────────┐")
        print("  │  ERROR ANALYSIS — Errors & problems by project      │")
        print("  └─────────────────────────────────────────────────────┘")
        print()
        print(f"  {len(rows)} error turns found\n")
        ranked_proj = sorted(by_project.items(), key=lambda x: x[1], reverse=True)
        max_p = ranked_proj[0][1] if ranked_proj else 1
        print("  Errors by project:")
        for proj, count in ranked_proj[:15]:
            bar = _bar(count, max_p)
            print(f"  {(proj or '—'):<28} {bar}  {count:>4}x")
        print()
        ranked_weeks = sorted(by_week.items(), key=lambda x: x[0])[-12:]
        if ranked_weeks:
            max_w = max(v for _, v in ranked_weeks)
            print("  Trend (last 12 weeks):")
            for week, count in ranked_weeks:
                bar = _bar(count, max_w, 20)
                print(f"  KW {week:<8} {bar}  {count:>3}x")
        print()

    # ── Friction-Analysis ──────────────────────────────────────────────────
    elif mode == "friction":
        pattern = " OR ".join(f'"{t}"' for t in _FRICTION_TERMS if " " not in t)
        rows = conn.execute(f"""
            SELECT s.topics, s.project, t.text, t.timestamp
            FROM turns_fts t
            JOIN sessions_meta s ON t.session_id = s.session_id
            WHERE t.turns_fts MATCH ?
            ORDER BY t.timestamp DESC
            LIMIT 800
        """, (pattern,)).fetchall()

        friction: dict[str, int] = {}
        proj_friction: dict[str, int] = {}
        for (topics_json, proj, text, ts) in rows:
            proj_friction[proj or "—"] = proj_friction.get(proj or "—", 0) + 1
            try:
                for t in json.loads(topics_json or "[]"):
                    friction[t] = friction.get(t, 0) + 1
            except Exception:
                pass

        print()
        print("  ┌─────────────────────────────────────────────────────┐")
        print("  │  FRICTION ANALYSIS — Recurring pain points          │")
        print("  └─────────────────────────────────────────────────────┘")
        print()
        print(f"  {len(rows)} turns with repetition signals found\n")

        print("  Friction by project:")
        ranked_pf = sorted(proj_friction.items(), key=lambda x: x[1], reverse=True)
        max_pf = ranked_pf[0][1] if ranked_pf else 1
        for proj, count in ranked_pf[:12]:
            bar = _bar(count, max_pf)
            label = "⚠️ " if count >= max_pf * 0.5 else "   "
            print(f"  {label}{(proj or '—'):<26} {bar}  {count:>4}x")
        print()

        if friction:
            print("  Friction by topic:")
            ranked_f = sorted(friction.items(), key=lambda x: x[1], reverse=True)
            max_f = ranked_f[0][1]
            for topic, count in ranked_f[:12]:
                bar = _bar(count, max_f)
                print(f"  {topic:<28} {bar}  {count:>4}x")
        print()

    # ── Timeline / Activity Heatmap ────────────────────────────────────────
    elif mode == "timeline":
        rows = conn.execute("""
            SELECT strftime('%Y-%W', first_ts) as week,
                   COUNT(*) as sessions,
                   SUM(turn_count) as turns
            FROM sessions_meta
            WHERE first_ts IS NOT NULL
            GROUP BY week
            ORDER BY week
        """).fetchall()
        if not rows:
            print("No timeline data.")
            return
        rows = rows[-24:]
        max_s = max(r[1] for r in rows)
        print()
        print("  ┌─────────────────────────────────────────────────────┐")
        print("  │  ACTIVITY TIMELINE — Sessions per week              │")
        print("  └─────────────────────────────────────────────────────┘")
        print()
        for (week, sessions, turns) in rows:
            bar = _bar(sessions, max_s, 32)
            intensity = "🔥" if sessions >= max_s * 0.8 else ("📈" if sessions >= max_s * 0.4 else "·")
            print(f"  {intensity} KW {week}  {bar}  {sessions:>3} sessions  ({turns or 0} turns)")
        print()
        total = sum(r[1] for r in rows)
        avg = total / len(rows)
        print(f"  Ø {avg:.1f} sessions/week · {total} sessions over {len(rows)} weeks")
        print()

    # ── Keyword-Analysis ───────────────────────────────────────────────────
    else:
        keyword = mode
        rows = conn.execute("""
            SELECT strftime('%Y-%W', timestamp) as week,
                   project, session_id, text
            FROM turns_fts
            WHERE turns_fts MATCH ?
            ORDER BY timestamp ASC
            LIMIT 1000
        """, (f'"{keyword}"',)).fetchall()

        if not rows:
            rows = conn.execute("""
                SELECT strftime('%Y-%W', timestamp) as week,
                       project, session_id, text
                FROM turns_fts
                WHERE turns_fts MATCH ?
                ORDER BY timestamp ASC
                LIMIT 1000
            """, (keyword,)).fetchall()

        if not rows:
            print(f'\n  No results for "{keyword}"\n')
            return

        by_week: dict[str, int] = {}
        by_proj: dict[str, int] = {}
        sessions: set[str] = set()
        for (week, proj, sid, text) in rows:
            by_week[week or "—"] = by_week.get(week or "—", 0) + 1
            by_proj[proj or "—"] = by_proj.get(proj or "—", 0) + 1
            sessions.add(sid)

        print()
        print(f'  ┌─────────────────────────────────────────────────────┐')
        print(f'  │  KEYWORD ANALYSIS — "{keyword}"')
        print(f'  └─────────────────────────────────────────────────────┘')
        print()
        print(f"  {len(rows)} mentions · {len(sessions)} sessions · {len(by_proj)} projects\n")

        print("  Frequency by project:")
        ranked_p = sorted(by_proj.items(), key=lambda x: x[1], reverse=True)
        max_p = ranked_p[0][1]
        for proj, count in ranked_p[:10]:
            bar = _bar(count, max_p)
            print(f"  {(proj or '—'):<28} {bar}  {count:>4}x")
        print()

        weeks = sorted(by_week.items())[-16:]
        if weeks:
            max_w = max(v for _, v in weeks)
            print("  Trend over time:")
            for week, count in weeks:
                bar = _bar(count, max_w, 24)
                trend = "↑" if count >= max_w * 0.6 else ("↓" if count <= max_w * 0.2 else "→")
                print(f"  {trend} KW {week}  {bar}  {count:>3}x")
        print()


# --- Projekt-Briefing ---
def generate_briefing(project_name: str):
    """
    Vollständiges Projekt-Briefing für ein Thema/Projekt.

    Strategie: Sessions werden via topics LIKE %{project}% gefiltert — weil
    bier-genuss, briefadler etc. als Topics in sessions_meta.topics gespeichert sind,
    nicht als eigenes Claude-Projekt (alle laufen unter SEO-BASE).

    Fallback: Wenn topics-Filter nichts findet, wird project LIKE %{project}% probiert.
    """
    conn = get_db()
    pname = project_name.lower().replace(" ", "-")

    # Primär: Topics-Filter (bier-genuss, briefadler, tiroler etc.)
    topic_rows = conn.execute(
        "SELECT COUNT(*) FROM sessions_meta WHERE topics LIKE ?",
        (f"%{pname}%",)
    ).fetchone()[0]

    # Fuzzy: Wenn exact match 0, alle bekannten Topics laden und Präfix-Match suchen
    if topic_rows == 0:
        import json as _json
        all_topic_rows = conn.execute("SELECT DISTINCT topics FROM sessions_meta WHERE topics IS NOT NULL").fetchall()
        known_topics = set()
        for (t,) in all_topic_rows:
            try:
                known_topics.update(_json.loads(t))
            except Exception:
                pass
        # Suche: Welches Topic startet mit pname oder enthält pname?
        candidates = [t for t in known_topics if t.startswith(pname) or pname.startswith(t) or pname in t]
        if candidates:
            # Kürzestes (spezifischstes) Topic nehmen
            pname = min(candidates, key=len)
            topic_rows = conn.execute(
                "SELECT COUNT(*) FROM sessions_meta WHERE topics LIKE ?",
                (f"%{pname}%",)
            ).fetchone()[0]

    if topic_rows > 0:
        filter_sql = "topics LIKE ?"
        filter_param = f"%{pname}%"
        filter_label = f"topic:{pname}"
    else:
        # Fallback: project-Spalte (für eigenständige Projekte wie SEO-BASE selbst)
        filter_sql = "project LIKE ?"
        filter_param = f"%{pname.replace('-', '%')}%"
        filter_label = f"project:{pname}"

    # --- Statistiken ---
    stats = conn.execute(f"""
        SELECT
            COUNT(*) as sessions,
            SUM(turn_count) as turns,
            MIN(first_ts) as first_ts,
            MAX(last_ts) as last_ts,
            SUM(active_minutes) as total_minutes,
            SUM(milestone_detected) as milestones,
            SUM(deploy_detected) as deploys
        FROM sessions_meta WHERE {filter_sql}
    """, (filter_param,)).fetchone()

    if not stats or stats[0] == 0:
        print(f"\n  Kein Projekt gefunden für: '{project_name}'")
        print(f"  Tipp: sss --list-topics  # verfügbare Themen anzeigen")
        print(f"        sss --fingerprint-all  # erst alle Sessions klassifizieren")
        return

    session_count, turn_count, first_ts_str, last_ts_str, total_minutes, milestones, deploys = stats
    turn_count = turn_count or 0
    total_minutes = total_minutes or 0
    active_hours = total_minutes / 60

    # Zeitraum berechnen
    today_str = datetime.now().strftime("%Y-%m-%d")
    first_date = first_ts_str[:10] if first_ts_str else "?"
    last_date  = last_ts_str[:10] if last_ts_str else "?"

    days_ago = "?"
    if last_ts_str:
        try:
            last_dt = datetime.fromisoformat(last_ts_str[:19])
            today_dt = datetime.now()
            diff = (today_dt - last_dt).days
            days_ago = f"vor {diff} Tag{'en' if diff != 1 else ''}" if diff > 0 else "heute"
        except Exception:
            days_ago = "?"

    # --- Top Topics dieser Sessions ---
    # Alle Sessions holen, dann Topics aggregieren
    all_session_topics = conn.execute(
        f"SELECT topics FROM sessions_meta WHERE {filter_sql} AND topics IS NOT NULL AND topics != '[]'",
        (filter_param,)
    ).fetchall()
    topic_counter: dict[str, int] = {}
    for (tj,) in all_session_topics:
        try:
            for t in json.loads(tj):
                if t.lower() != pname:  # eigenes Projekt-Label nicht mitzählen
                    topic_counter[t] = topic_counter.get(t, 0) + 1
        except Exception:
            pass
    top_topics = sorted(topic_counter.items(), key=lambda x: -x[1])[:5]

    # --- Letzte 5 Milestone-Sessions ---
    milestone_rows = conn.execute(f"""
        SELECT session_id, last_ts, turn_count, deploy_detected, active_minutes
        FROM sessions_meta
        WHERE {filter_sql} AND milestone_detected = 1
        ORDER BY last_ts DESC LIMIT 5
    """, (filter_param,)).fetchall()

    # --- Letzte 3 Sessions gesamt ---
    recent_rows = conn.execute(f"""
        SELECT session_id, last_ts, turn_count, milestone_detected, deploy_detected, active_minutes
        FROM sessions_meta
        WHERE {filter_sql}
        ORDER BY last_ts DESC LIMIT 3
    """, (filter_param,)).fetchall()

    # --- Bekannte Probleme: Sessions mit Fehler-Turns (letzte 30 Tage) ---
    since_30d = (datetime.now().replace(hour=0, minute=0, second=0)
                 .__class__.fromisocalendar(datetime.now().year, max(1, datetime.now().isocalendar()[1] - 4), 1)
                 .isoformat())
    # Einfacherer Ansatz: letzten 30 Tage via String-Vergleich
    from datetime import timedelta
    since_30d = (datetime.now() - timedelta(days=30)).strftime("%Y-%m-%d")

    # Sessions IDs für dieses Projekt holen (max 100 für IN-Clause)
    project_sids = [r[0] for r in conn.execute(
        f"SELECT session_id FROM sessions_meta WHERE {filter_sql} AND last_ts >= ? ORDER BY last_ts DESC LIMIT 100",
        (filter_param, since_30d)
    ).fetchall()]

    problem_sessions: list[tuple] = []
    if project_sids:
        placeholders = ",".join("?" * len(project_sids))
        # Turns mit Fehler-Keywords: gruppiert pro Session, älteste zuerst → "bekannte Probleme"
        # Nur hochsignalige Fehler-Keywords (nicht "fix"/"problem" — zu breit in deutschen Texten)
        prob_turns = conn.execute(f"""
            SELECT f.session_id, f.timestamp, f.text
            FROM turns_fts f
            INNER JOIN sessions_meta m ON f.session_id = m.session_id
            WHERE f.session_id IN ({placeholders})
              AND f.role = 'assistant'
              AND LENGTH(f.text) > 200
              AND (
                f.text LIKE '%fehlgeschlagen%' OR f.text LIKE '%traceback%'
                OR f.text LIKE '%exit code 1%' OR f.text LIKE '%broken%'
                OR f.text LIKE '%noindex%' OR f.text LIKE '%404%'
              )
            ORDER BY f.timestamp DESC LIMIT 10
        """, project_sids).fetchall()

        # Pro Session max 1 Eintrag, max 3 Sessions
        HIGH_SIGNAL = ["fehlgeschlagen", "traceback", "exit code 1", "broken", "noindex", "404"]
        seen_sids: set[str] = set()
        for sid, ts, text in prob_turns:
            if sid not in seen_sids:
                seen_sids.add(sid)
                # Knappe Zusammenfassung: erste Zeile des Texts die den Begriff enthält
                summary = ""
                for line in text.split("\n"):
                    line_l = line.lower()
                    if any(kw in line_l for kw in HIGH_SIGNAL):
                        summary = line.strip()[:100]
                        break
                if not summary:
                    summary = text[:100].strip()
                problem_sessions.append((ts[:10], sid[:8], summary))
            if len(problem_sessions) >= 3:
                break

    # --- Output ---
    width = 52
    title = f"PROJEKT-BRIEFING: {project_name}"
    print(f"\n\033[1m╔{'═' * width}╗\033[0m")
    print(f"\033[1m║  {title:<{width-2}}║\033[0m")
    print(f"\033[1m║  Stand: {today_str} | {session_count} Sessions | {turn_count:,} Turns{'':<{width-2-len(f'Stand: {today_str} | {session_count} Sessions | {turn_count:,} Turns')}}║\033[0m")
    print(f"\033[1m╚{'═' * width}╝\033[0m")

    print(f"\n\033[1m## Aktivität\033[0m")
    print(f"  Erste Session:   {first_date}")
    print(f"  Letzte Session:  {last_date}  ({days_ago})")
    print(f"  Aktiv-Zeit est.: {active_hours:.1f}h  |  Milestones: {milestones}  |  Deploys: {deploys}")
    print(f"  Filter:          {filter_label}")

    if top_topics:
        print(f"\n\033[1m## Top Topics (Co-Themen)\033[0m")
        topics_str = " · ".join(f"{t} ({c})" for t, c in top_topics)
        print(f"  {topics_str}")

    if milestone_rows:
        print(f"\n\033[1m## Letzte {len(milestone_rows)} Milestones\033[0m")
        for sid, last_ts, turns, dep, act_min in milestone_rows:
            date = last_ts[:10] if last_ts else "?"
            deploy_flag = "  deploy ✓" if dep else ""
            time_str = f"  {(act_min or 0)//60}h{(act_min or 0)%60}m" if act_min and act_min > 0 else ""
            print(f"  [{date}] {turns} Turns{time_str}{deploy_flag}")
            print(f"    \033[36m→ read-session {sid[:8]} --context\033[0m")
    else:
        print(f"\n\033[1m## Milestones\033[0m")
        print(f"  Keine Milestone-Sessions gefunden. Tipp: sss --fingerprint-all")

    if problem_sessions:
        print(f"\n\033[1m## Bekannte Probleme (letzte 30 Tage)\033[0m")
        for date, sid, summary in problem_sessions:
            print(f"  [{date}] {summary}")
            print(f"    \033[36m→ read-session {sid} --last 5\033[0m")

    print(f"\n\033[1m## Letzte {len(recent_rows)} Sessions\033[0m")
    for sid, last_ts, turns, ms, dep, act_min in recent_rows:
        date = last_ts[:10] if last_ts else "?"
        flags = []
        if ms:
            flags.append("milestone ✓")
        if dep:
            flags.append("deploy ✓")
        flags_str = " · ".join(flags)
        time_str = f"  {(act_min or 0)//60}h{(act_min or 0)%60}m" if act_min and act_min > 0 else ""
        print(f"  [{date}] {turns} Turns{time_str}  {flags_str}")
        print(f"    \033[36m→ read-session {sid[:8]} --context\033[0m")
    print()


# --- Main ---
def main():
    parser = argparse.ArgumentParser(description="Smart Session Search — BM25 + Semantic")
    parser.add_argument("query", nargs="*", help="Suchbegriff")
    parser.add_argument("--semantic", "-s", action="store_true", help="Semantic-Suche (pre-computed, ~0.4s)")
    parser.add_argument("--hybrid", "-H", action="store_true", help="BM25 + Semantic (beste Qualität)")
    parser.add_argument("--project", "-p", default=None, help="Projekt-Filter (Substring)")
    parser.add_argument("--role", "-r", choices=["user","assistant"], default=None)
    parser.add_argument("--since", default=None, help="Ab Datum (YYYY-MM-DD)")
    parser.add_argument("--limit", "-l", type=int, default=10)
    parser.add_argument("--any", "-a", action="store_true",
                        help="OR-Suche: mind. ein Wort muss vorkommen (statt AND für alle Wörter)")
    parser.add_argument("--index", "-i", action="store_true", help="FTS5 aufbauen/aktualisieren (schnell)")
    parser.add_argument("--embed", "-e", action="store_true",
                        help="Embeddings für alle uneingebetteten Turns berechnen (~60min initial)")
    parser.add_argument("--force", "-f", action="store_true", help="Index komplett neu aufbauen")
    parser.add_argument("--stats", action="store_true", help="Index-Statistiken")
    parser.add_argument("--milestone", action="store_true",
                        help="Nur Sessions mit erkanntem Milestone/Go-Live/Abschluss")
    parser.add_argument("--deployed", action="store_true",
                        help="Nur Sessions in denen ein Deploy-Befehl ausgeführt wurde")
    parser.add_argument("--oldest", action="store_true",
                        help="Älteste Treffer zuerst (statt Relevanz) — für ersten Auftritt eines Themas")
    parser.add_argument("--fingerprint-all", action="store_true",
                        help="Alle bestehenden Sessions klassifizieren (Batch-Run, ~1-2 Min)")
    parser.add_argument("--list-milestones", action="store_true",
                        help="Alle Milestone-Sessions chronologisch auflisten (kein Query nötig)")
    parser.add_argument("--list-topics", action="store_true",
                        help="Topic-Verteilung aus sessions_meta ausgeben")
    parser.add_argument("--unique", "-u", action="store_true",
                        help="Nur ein Treffer pro Session (bester) — verhindert Same-Session-Dominanz")
    parser.add_argument("--briefing", metavar="PROJECT", default=None,
                        help="Vollständiges Projekt-Briefing (z.B. --briefing bier-genuss)")
    parser.add_argument("--open", metavar="TOPIC", default=None,
                        help="Letzte offene (nicht abgeschlossene) Session zu einem Topic finden")
    parser.add_argument("--continuation", metavar="TOPIC", default=None,
                        help="Find predecessor sessions for a topic (session chains)")
    parser.add_argument("--analyze", metavar="MODE", default=None,
                        help="Analytics: topics | projects | errors | friction | timeline | <keyword>")

    args = parser.parse_args()

    if getattr(args, "continuation", None):
        topic = args.continuation
        conn = get_db()
        import json as _json
