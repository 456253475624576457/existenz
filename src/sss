# --- Direct milestone/deployed search (leer query → kein FTS5) ---
def search_direct_filter(milestone_only: bool = False, deployed_only: bool = False,
                          project: str = None, since: str = None, limit: int = 20,
                          oldest_first: bool = False) -> list[dict]:
    """
    Direkte SQL-Abfrage auf sessions_meta — kein FTS5, kein leerer Query-String.
    Für: sss "" --milestone und sss "" --deployed.

    Gibt Sessions-Metadaten zurück (keine Turn-Snippets).
    """
    conn = get_db()

    filter_parts = []
    if milestone_only:
        filter_parts.append("milestone_detected = 1")
    if deployed_only:
        filter_parts.append("deploy_detected = 1")

    where = " AND ".join(filter_parts) if filter_parts else "1=1"
    params = []

    sql = f"""
        SELECT session_id, project, last_ts, turn_count,
               milestone_detected, deploy_detected, active_minutes
        FROM sessions_meta
        WHERE {where}
    """
    if project:
        sql += " AND project LIKE ?"
        params.append(f"%{project.replace(' ', '%')}%")
    if since:
        sql += " AND last_ts >= ?"
        params.append(since)
    order = "ASC" if oldest_first else "DESC"
    sql += f" ORDER BY last_ts {order} LIMIT ?"
    params.append(limit)

    rows = conn.execute(sql, params).fetchall()

    results = []
    for sid, proj, last_ts, turns, milestone, deployed, active_min in rows:
        flags = []
        if milestone:
            flags.append("milestone ✓")
        if deployed:
            flags.append("deploy ✓")
        flags_str = "  ".join(flags)
        time_str = f"  {active_min}min" if active_min else ""
        results.append({
            "session_id": sid,
            "project": proj,
            "timestamp": last_ts,
            "role": "session",
            "score": 0.0,
            "snippet": f"({turns} Turns){time_str}  {flags_str}",
            "text_preview": f"({turns} Turns){time_str}  {flags_str}",
        })
    return results


